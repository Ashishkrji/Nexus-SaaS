# ============================================
# SERVER
# ============================================
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ============================================
# DATABASE — MongoDB Atlas (FREE M0 Cluster)
# Sign up: mongodb.com/atlas
# Free: 512MB, shared cluster, no credit card
# ============================================
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/gbp_optimizer?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/gbp_optimizer

# ============================================
# AUTH
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-key

# ============================================
# GOOGLE OAUTH + BUSINESS PROFILE API
# Sign up: console.cloud.google.com (FREE)
# Enable: Google Business Profile API
#         Google OAuth2 API
#         Google My Business API
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google/callback

# ============================================
# AI — FREE TIER (NVIDIA NIM)
# Sign up: build.nvidia.com (FREE)
# Free credits given on signup
# Models: Llama 3.1 70B, Mistral, Nemotron
# ============================================
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=meta/llama-3.1-70b-instruct

# ============================================
# AI — OPENAI (User keys or system fallback)
# Sign up: platform.openai.com
# Models: GPT-4o, GPT-4o Mini, GPT-4 Turbo
# ============================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ============================================
# AI — ANTHROPIC (Claude)
# Sign up: console.anthropic.com
# Models: Claude 4 Sonnet, Claude 3.5 Sonnet, Claude 3 Haiku
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ============================================
# AI — GOOGLE GEMINI
# Sign up: aistudio.google.com (FREE tier available)
# Models: Gemini 2.5 Flash, Gemini 2.0 Flash, Gemini 1.5 Pro
# ============================================
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx

# ============================================
# AI — xAI GROK
# Sign up: console.x.ai
# Models: Grok 2, Grok 2 Mini
# ============================================
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxx

# ============================================
# EMAIL — Gmail SMTP (FREE)
# 1. Gmail account banao (dedicated)
# 2. 2FA enable karo
# 3. App Password generate karo:
#    myaccount.google.com → Security → App passwords
# Free: ~500 emails/day
# ============================================
GMAIL_USER=yourapp@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
FROM_EMAIL=NexusSaaS <yourapp@gmail.com>

# ============================================
# STORAGE — Local (FREE)
# Files /uploads folder mein save honge
# Production mein server ka disk use hoga
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
# 5MB in bytes

# ============================================
# ENCRYPTION
# ============================================
ENCRYPTION_KEY=32-character-random-string-here!!

# ============================================
# APP CONFIG — Plan Limits
# ============================================
AI_DEFAULT_PROVIDER=nvidia
ENABLE_FREE_TIER=true

# Free Plan Limits
FREE_PLAN_API_LIMIT=500
FREE_PLAN_WORKSPACE_LIMIT=1
FREE_PLAN_TEAM_LIMIT=1

# Pro Plan Limits
PRO_PLAN_API_LIMIT=25000
PRO_PLAN_WORKSPACE_LIMIT=10
PRO_PLAN_TEAM_LIMIT=5

# Business Plan Limits
BUSINESS_PLAN_API_LIMIT=200000
BUSINESS_PLAN_WORKSPACE_LIMIT=50
BUSINESS_PLAN_TEAM_LIMIT=25

# Agency Plan — Unlimited
